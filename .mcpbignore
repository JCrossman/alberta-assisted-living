# Files excluded from the .mcpb bundle (gitignore syntax).
# The UV runtime resolves dependencies from pyproject.toml/uv.lock on the
# user's machine, so the bundle only needs the manifest and the package source.

# Version control / tooling
.git/
.github/
.gitignore
.mcpbignore
.mcp.json

# Local environments and caches
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Build artifacts
dist/
build/
*.egg-info/
*.mcpb

# Not needed at runtime
tests/
docs/
COMPLIANCE.md
AGENTS.md
CLAUDE.md
